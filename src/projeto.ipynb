   "metadata": {},
   "source": [
    "# Montar composição de imagem anual"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 16,
   "id": "47423115",
   "metadata": {},
   "outputs": [],
   "source": [
    "\n",
    "def montar_imagem_anual(regiao, ano):\n",
    "\n",
    "    imagens = []\n",
    "\n",
    "    for mes in range(1, 13):\n",
    "\n",
    "        mes_str = str(mes).zfill(2)\n",
    "\n",
    "        img = carregar_imagem_bruta(\n",
    "            regiao,\n",
    "            ano,\n",
    "            mes_str\n",
    "        )\n",
    "\n",
    "        if img is not None:\n",
    "            imagens.append(img)\n",
    "\n",
    "    if len(imagens) == 0:\n",
    "        return None\n",
    "\n",
    "    ref_shape = imagens[0].shape\n",
    "\n",
    "    imagens_ajustadas = []\n",
    "\n",
    "    for img in imagens:\n",
    "\n",
    "        if img.shape != ref_shape:\n",
    "\n",
    "            img = cv2.resize(\n",
    "                img,\n",
    "                (ref_shape[1], ref_shape[0]),\n",
    "                interpolation=cv2.INTER_LINEAR\n",
    "            )\n",
    "\n",
    "        imagens_ajustadas.append(img)\n",
    "\n",
    "    stack = np.stack(\n",
    "        imagens_ajustadas,\n",
    "        axis=0\n",
    "    )\n",
    "\n",
    "    composto = np.median(\n",
    "        stack,\n",
    "        axis=0\n",
    "    )\n",
    "\n",
    "    return composto\n"
   ]
  },
