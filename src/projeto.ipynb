    "\n",
    "def extrair_features_pixel(img, i, j):\n",
    "\n",
    "    pixel = img[i, j]\n",
    "\n",
    "    vizinhanca = img[\n",
    "        i-1:i+2,\n",
    "        j-1:j+2\n",
    "    ]\n",
    "\n",
    "    media_viz = np.mean(vizinhanca)\n",
    "    desvio_viz = np.std(vizinhanca)\n",
    "    max_viz = np.max(vizinhanca)\n",
    "\n",
    "    return [\n",
    "        pixel,\n",
    "        media_viz,\n",
    "        desvio_viz,\n",
    "        max_viz\n",
    "    ]\n"
   ]
