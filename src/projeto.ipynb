  {
   "cell_type": "markdown",
   "id": "2e8034cb",
   "metadata": {},
   "source": [
    "# Máscara de expansão prevista"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 21,
   "id": "b5ed3788",
   "metadata": {},
   "outputs": [],
   "source": [
    "\n",
    "def gerar_expansao(regiao):\n",
    "    pred_img, img_final = previsao(regiao)\n",
    "\n",
    "    crescimento_previsto = (\n",
    "        pred_img > img_final + THRESHOLD_EXPANSAO\n",
    "    ).astype(np.uint8) * 255\n",
    "\n",
    "    return pred_img, img_final, crescimento_previsto\n"
   ]
  },
